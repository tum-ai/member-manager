# Server environment template.
# This file is the source of truth for server-side configuration names.
# Let `pnpm setup:local` generate `server/.env.local` for Docker-local dev.
# Server precedence: .env.local > process env > .env.

# Core runtime
PORT=8787
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Encrypts sensitive member, SEPA, and reimbursement fields.
# Do not rotate in production without a decrypt/re-encrypt migration plan.
FIELD_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Canonical public app URL for Slack buttons, emails, and signed links.
APP_BASE_URL=http://localhost:5173

# Local admin bootstrap. Keep disabled outside local development.
ENABLE_LOCAL_ADMIN_BOOTSTRAP=false
LOCAL_ADMIN_EMAILS=you@example.com

# Receipt extraction. Leave unset to keep manual reimbursement entry only.
OPENAI_API_KEY=

# Slack notifications and interactive finance actions.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# TUM.ai Days scheduled Slack sends.
CRON_SECRET=
RSVP_TARGET_EMAILS=
TEST_RSVP_EMAIL=

# Footer bug reports -> GitHub issues.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_BASE64=
BUG_REPORT_GITHUB_REPOSITORY=tum-ai/member-manager
BUG_REPORT_GITHUB_OWNER=
BUG_REPORT_GITHUB_REPO=
BUG_REPORT_GITHUB_LABELS=
BUG_REPORT_SLACK_CHANNEL_ID=C0B3YGL3XS5

# Research project metadata. Defaults in code to the production website API.
WEBSITE_RESEARCH_API_URL=https://www.tum-ai.com/api/getResearch

# Partner Portal integrations.
# `PARTNER_EXPORT_TOKEN` authorizes the internal CV export endpoint.
# Generic API values enable partner management. When absent, the server falls
# back to the jobs API values so existing deployments need no new secret.
PARTNER_EXPORT_TOKEN=
PARTNER_PORTAL_API_URL=
PARTNER_PORTAL_API_TOKEN=
# Jobs API values enable Partner Portal jobs and pending request review.
PARTNER_PORTAL_JOBS_API_URL=
PARTNER_PORTAL_JOBS_API_TOKEN=

# BuchhaltungsButler receipt sync.
BUCHHALTUNGSBUTLER_SYNC_ENABLED=false
BUCHHALTUNGSBUTLER_API_CLIENT=
BUCHHALTUNGSBUTLER_API_SECRET=
BUCHHALTUNGSBUTLER_API_KEY=
BUCHHALTUNGSBUTLER_API_BASE_URL=https://webapp.buchhaltungsbutler.de/api/v1

# Contract emails through Resend. Required for partner signing links,
# clarification emails, and status-change notifications to actually send;
# when unset these paths are skipped gracefully (no email is sent).
RESEND_API_KEY=
CONTRACT_EMAIL_FROM=contracts@tum-ai.com
# Recipient for contract status-change notifications sent to the legal team.
# When unset, only the contract creator is notified on status changes.
CONTRACT_LEGAL_EMAIL=

# Hosted contract signing through OpenSign.
OPENSIGN_API_TOKEN=
OPENSIGN_BASE_URL=https://eu-app.opensignlabs.com/api/v1.2
OPENSIGN_WEBHOOK_SECRET=
OPENSIGN_WIDGETS_JSON=
