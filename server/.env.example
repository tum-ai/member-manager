# Server Environment Variables (template)
#
# Copy to `.env` for hosted-Supabase dev, or let `pnpm setup:local` generate
# `.env.local` for local-Supabase dev.
#
# Precedence (highest wins): process env > .env.local > .env
# See docs/development.md for the full story.

PORT=8787

# Hosted Supabase project. Must be https:// in any non-local env
# (enforced by assertSecureRemoteUrl).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Strong random 32+ char secret. Encrypts sensitive member/SEPA fields before
# persistence. ROTATING OR LOSING THIS KEY ORPHANS EXISTING ROWS - see
# docs/deployment.md before touching it in production.
FIELD_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Optional. Enables automatic receipt extraction in the reimbursement tool.
# Without this, receipts still attach and users fill/correct fields manually.
OPENAI_API_KEY=

# Required for in-app bug reports. Create/install a GitHub App with Issues
# read/write access on tum-ai/member-manager.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# PEM private key. Escaped newlines (\\n) are OK.
GITHUB_APP_PRIVATE_KEY=
# Alternative for hosts that dislike multiline secrets.
GITHUB_APP_PRIVATE_KEY_BASE64=
# Optional target override; defaults in code to tum-ai/member-manager.
BUG_REPORT_GITHUB_REPOSITORY=tum-ai/member-manager
# Optional. Set only if the labels already exist in the repo.
BUG_REPORT_GITHUB_LABELS=
# Optional comma-separated Slack user IDs to tag in bug-report notifications.
# Order determines round-robin rotation by GitHub issue number.
BUG_REPORT_SLACK_ASSIGNEES=U123,U456

# Optional. Enables Slack DMs for certificate/admin and reimbursement finance
# review notifications. Also required for bug-report Slack notifications.
SLACK_BOT_TOKEN=

# Slack channel receiving bug-report issue notifications. Defaults in code to the
# Member Manager bug-report channel, but keep this explicit in deployed envs.
BUG_REPORT_SLACK_CHANNEL_ID=C0B3YGL3XS5

# Comma-separated list of allowed origins. In prod, set to the public domain.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Local-only helper: must be explicitly enabled for authenticated allowlisted
# users to auto-bootstrap themselves to `admin` after login.
ENABLE_LOCAL_ADMIN_BOOTSTRAP=false

# Comma-separated email allowlist for the local bootstrap helper above.
LOCAL_ADMIN_EMAILS=you@example.com

# Website API mirror for current public research projects.
WEBSITE_RESEARCH_API_URL=https://www.tum-ai.com/api/getResearch
