# Server staging environment template.
# Copy to `.env.staging.local` and fill with the dedicated staging Supabase project.
# Used by root `pnpm dev:staging`; do not put production credentials here.

PORT=8787
SUPABASE_URL=https://<staging-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# Must match the key used for existing encrypted rows in staging.
FIELD_ENCRYPTION_KEY=<staging-field-encryption-key>

CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
ENABLE_LOCAL_ADMIN_BOOTSTRAP=false
LOCAL_ADMIN_EMAILS=

# Optional local integrations for staging-mode app dev.
OPENAI_API_KEY=
SLACK_BOT_TOKEN=
BUG_REPORT_SLACK_CHANNEL_ID=C0B3YGL3XS5
WEBSITE_RESEARCH_API_URL=https://www.tum-ai.com/api/getResearch
