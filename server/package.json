{
	"name": "@member-manager/server",
	"version": "1.0.0",
	"description": "Backend API for Member Manager",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"dev:local": "tsx watch src/index.ts",
		"build": "tsc",
		"backfill:encryption": "tsx src/scripts/backfillSensitiveData.ts",
		"backfill:member-cvs": "tsx src/scripts/backfillMemberCvs.ts",
		"start": "node dist/index.js",
		"lint": "biome check .",
		"lint:apply": "biome check . --write",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test test/**/*.test.ts",
		"test:coverage": "c8 --reporter=text-summary --reporter=lcov --reporter=json-summary --all --src=src --check-coverage --lines=70 --functions=70 --branches=50 --statements=70 tsx --test test/**/*.test.ts"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/rate-limit": "^10.3.0",
		"@member-manager/shared": "workspace:*",
		"@supabase/supabase-js": "^2.108.2",
		"dotenv": "^16.6.1",
		"fastify": "^5.8.5",
		"fastify-plugin": "^5.1.0",
		"ibantools": "^4.5.4",
		"jszip": "^3.10.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^24.13.2",
		"c8": "^11.0.0",
		"cross-env": "^10.1.0",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3"
	}
}
