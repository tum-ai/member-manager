{
	"$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!!**/dist"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noUselessUndefinedInitialization": "error",
				"useDateNow": "error"
			},
			"style": {
				"noDefaultExport": "error",
				"noNonNullAssertion": "error",
				"noUselessElse": "error",
				"noYodaExpression": "error",
				"useCollapsedElseIf": "error",
				"useExportType": "error",
				"useForOf": "error",
				"useImportType": "error",
				"useShorthandAssign": "error",
				"useShorthandFunctionType": "error",
				"useThrowNewError": "error",
				"useThrowOnlyError": "error"
			},
			"suspicious": {
				"noConstEnum": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": [
				"**/*.stories.tsx",
				"**/features/**/*Page.tsx",
				"**/App.tsx",
				"**/main.tsx",
				"**/*.config.ts",
				"**/*.config.mts",
				"**/.storybook/**",
				"**/api/**/*.ts"
			],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
