{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/"
    }
  ],
  "crons": [
    {
      "path": "/api/tum-ai-days/send-pending",
      "schedule": "*/10 * * * *"
    }
  ]
}

