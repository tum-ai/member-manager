{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"env": {
		"DO_NOT_TRACK": "1"
	},
	"permissions": {
		"allow": [
			"Bash(pnpm gate)",
			"Bash(pnpm lint)",
			"Bash(pnpm lint:staged)",
			"Bash(pnpm lint:apply)",
			"Bash(pnpm typecheck)",
			"Bash(pnpm test)",
			"Bash(pnpm test:coverage)",
			"Bash(pnpm test:scripts)",
			"Bash(pnpm test:e2e)",
			"Bash(pnpm test:e2e:*)",
			"Bash(pnpm build)",
			"Bash(pnpm build:shared)",
			"Bash(pnpm check:filesize)",
			"Bash(pnpm setup:local)",
			"Bash(pnpm supabase:start)",
			"Bash(pnpm supabase:status)",
			"Bash(pnpm supabase:reset)",
			"Bash(pnpm supabase:stop)",
			"Bash(pnpm supabase:migrations:check)",
			"Bash(pnpm --filter @member-manager/*:*)",
			"Bash(pnpm -r run *)",
			"Bash(pnpm exec playwright:*)",
			"Bash(pnpm exec vitest:*)",
			"Bash(npx @biomejs/biome:*)",
			"Bash(git status)",
			"Bash(git status:*)",
			"Bash(git diff)",
			"Bash(git diff:*)",
			"Bash(git log)",
			"Bash(git log:*)",
			"Bash(git show:*)",
			"Bash(git add:*)",
			"Bash(git commit:*)",
			"Bash(git branch)",
			"Bash(git branch:*)",
			"Bash(git checkout:*)",
			"Bash(git switch:*)",
			"Bash(gh pr view:*)",
			"Bash(gh pr diff:*)",
			"Bash(gh pr list:*)",
			"Bash(gh pr comment:*)",
			"Bash(gh api:*)",
			"Read",
			"Edit",
			"Write",
			"Grep",
			"Glob"
		],
		"deny": [
			"Bash(git push --force:*)",
			"Bash(git push -f:*)",
			"Bash(git reset --hard:*)",
			"Bash(git clean -fd:*)",
			"Bash(supabase db push:*)",
			"Bash(supabase link:*)",
			"Read(**/.env)",
			"Read(**/.env.local)",
			"Read(supabase/.env)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/git-guard.sh\""
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/biome-format.sh\""
					}
				]
			}
		]
	}
}
