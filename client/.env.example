# Client Environment Variables (template)
#
# Copy to `.env` for hosted-Supabase dev, or let `pnpm setup:local` generate
# `.env.local` for local-Supabase dev.
#
# Precedence (highest wins): process env > .env.local > .env
# See docs/development.md for the full story.

# Hosted Supabase project (values from the Supabase dashboard):
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Where Slack OIDC should redirect back to after login. MUST exactly match one
# of the URLs in Supabase Auth -> URL Configuration -> Redirect URLs (trailing
# slash included). See docs/deployment.md.
VITE_SLACK_CALLBACK_URL=http://localhost:5173/
