# Client Environment Variables (template)
#
# Copy to `.env` only for ad-hoc hosted dev, or let `pnpm setup:local` generate
# `.env.local` for Docker-local dev.
# Preferred hosted mode: copy `.env.staging.example` to `.env.staging.local`
# and run root `pnpm dev:staging`.
#
# Precedence (highest wins): process env > .env.local > .env
# See docs/development.md for the full story.

# Hosted Supabase project (values from the staging Supabase dashboard):
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_PROXY_TARGET=http://127.0.0.1:8787

# Optional fallback override for where Slack OIDC should redirect back to after
# login. If unset, the client uses the current browser origin, which is what
# makes Vercel previews return to their own deployment URL.
# If you set this explicitly, it MUST match an allowed Supabase redirect URL.
VITE_SLACK_CALLBACK_URL=http://localhost:5173/
