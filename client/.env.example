# Client environment template.
# This file is the source of truth for browser/Vite configuration names.
# Let `pnpm setup:local` generate `client/.env.local` for Docker-local dev.
# Client/Vite precedence: process env > .env.local > .env.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Local dev-server proxy target. Vercel production uses same-origin /api.
VITE_API_PROXY_TARGET=http://127.0.0.1:8787

# Optional Slack OAuth fallback. If unset, the current browser origin is used.
VITE_SLACK_CALLBACK_URL=http://localhost:5173/
