# Client Environment Variables Example
# Copy this file to .env and fill in the values

# For local development, use these values (from `supabase status`):
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<from supabase status>

# For production, use your hosted Supabase project:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API Server URL (for local development, this is your backend server)
VITE_API_URL=http://localhost:3000
