# Client staging environment template.
# Copy to `.env.staging.local` and fill with the dedicated staging Supabase project.
# Used by root `pnpm dev:staging`; do not put production credentials here.

VITE_SUPABASE_URL=https://<staging-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<staging-anon-key>
VITE_API_PROXY_TARGET=http://127.0.0.1:8787

# Optional. If unset, Slack OAuth uses the current browser origin.
# The staging Supabase auth allow-list must include the chosen URL.
VITE_SLACK_CALLBACK_URL=http://localhost:5173/
