{
	"name": "member-manager",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm dev:local",
		"dev:local": "pnpm supabase:start && pnpm setup:local && pnpm -r --parallel --filter @member-manager/client --filter @member-manager/server run dev:local",
		"dev:staging": "node scripts/dev-staging.mjs",
		"gate": "pnpm lint && pnpm test && pnpm build",
		"build": "pnpm -r run build",
		"test": "pnpm test:scripts && pnpm -r run test",
		"test:scripts": "node --test scripts/*.test.mjs",
		"lint": "biome check api && pnpm -r run lint",
		"lint:staged": "biome check --staged --no-errors-on-unmatched",
		"lint:apply": "pnpm -r --parallel run lint:apply",
		"hooks:install": "node scripts/install-git-hooks.mjs",
		"setup:local": "node scripts/setup-local-env.mjs",
		"supabase:start": "node scripts/supabase-start.mjs",
		"supabase:stop": "supabase stop",
		"supabase:status": "supabase status",
		"supabase:reset": "supabase db reset",
		"supabase:migrations:check": "node scripts/check-supabase-migrations.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.7",
		"@types/node": "^20.11.25"
	}
}
