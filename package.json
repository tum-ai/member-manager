{
	"name": "member-manager",
	"private": true,
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"packageManager": "pnpm@10.34.3",
	"scripts": {
		"dev": "pnpm dev:local",
		"dev:local": "pnpm build:shared && pnpm supabase:start && pnpm setup:local && pnpm -r --parallel --filter @member-manager/client --filter @member-manager/server run dev:local",
		"gate": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
		"build": "turbo run build",
		"build:shared": "pnpm --filter @member-manager/shared run build",
		"typecheck": "turbo run typecheck",
		"test": "pnpm test:scripts && turbo run test",
		"test:coverage": "pnpm test:scripts && turbo run test:coverage",
		"test:scripts": "node --test scripts/*.test.mjs",
		"check:filesize": "node scripts/check-file-size.mjs",
		"test:e2e": "playwright test",
		"test:e2e:finance-live": "E2E_BB_LIVE=true playwright test e2e/finance-transactions.spec.ts",
		"test:e2e:ui": "playwright test --ui",
		"lint": "biome check api && turbo run lint && pnpm check:filesize",
		"lint:staged": "biome check --staged --no-errors-on-unmatched",
		"lint:apply": "pnpm -r --parallel run lint:apply",
		"doctor": "node scripts/doctor.mjs",
		"prepare": "node scripts/install-git-hooks.mjs --quiet",
		"hooks:install": "node scripts/install-git-hooks.mjs",
		"setup:local": "node scripts/setup-local-env.mjs",
		"supabase:start": "node scripts/supabase-start.mjs",
		"supabase:stop": "supabase stop",
		"supabase:status": "supabase status",
		"supabase:reset": "supabase db reset",
		"supabase:migrations:check": "node scripts/check-supabase-migrations.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.5",
		"@playwright/test": "^1.61.1",
		"@types/node": "^24.13.3",
		"turbo": "^2.10.6"
	}
}
