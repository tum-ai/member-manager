# Local Supabase OAuth provider secrets.
# Copy this file to `supabase/.env.local` and fill in real values.
# Loaded automatically by `pnpm supabase:start` (scripts/supabase-start.mjs).
# `supabase/.env.local` is gitignored via the `.env.local` rule.

# Slack Sign-In with OpenID Connect (the "Continue with Slack" button).
# Grab these from the Slack app registered against the hosted TUM.ai Supabase
# project (same app, reused for local). Make sure the Slack app's
# "Redirect URLs" list includes http://127.0.0.1:54321/auth/v1/callback.
SUPABASE_AUTH_EXTERNAL_SLACK_OIDC_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_SLACK_OIDC_SECRET=
